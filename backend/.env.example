PORT=3847
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# 2.0-flash на free tier часто с лимитом 0; lite / 2.5-flash надёжнее
GEMINI_MODEL=gemini-2.5-flash-lite
# Через запятую, если первая модель отдаёт 429
# GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-flash-latest
# @BotFather
TELEGRAM_BOT_TOKEN=
# Опционально: если задан — смена промпта только с заголовком X-CRM-SECRET
CRM_API_SECRET=
# Доп. origin через запятую. Любой http://localhost:* и http://127.0.0.1:* разрешён, если CORS_STRICT не равен 1
CORS_ORIGIN=http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:5174,http://localhost:5174
# CORS_STRICT=1
# Optional bootstrap admin on first run (will NOT overwrite existing user)
# CRM_SEED_ADMIN_EMAIL=
# CRM_SEED_ADMIN_PASSWORD=
# CRM_SEED_ADMIN_NAME=Admin
# Strongly recommended in production: persistent absolute path to SQLite file
# SQLITE_PATH=/var/lib/d7-crm/d7-crm.sqlite
